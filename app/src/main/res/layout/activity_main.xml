<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="5dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_plant"
                android:layout_marginEnd="8dp"
                app:tint="#2E7D32" />


        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#F2F2F2"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Twoje zapytanie"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:drawableStart="@android:drawable/ic_menu_search"
                        android:drawablePadding="8dp"/>

                    <EditText
                        android:id="@+id/inputPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="4"
                        android:gravity="top"
                        android:hint="Napisz zapytanie..."
                        android:padding="12dp"
                        android:background="#F2F2F2"
                        android:textColor="#000000"
                        android:textColorHint="#888888"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/charCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0 znaków"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp"
                        android:textColor="#666666"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnOptimize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚀 Optymalizuj"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#F2F2F2"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Zoptymalizowane zapytanie"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:drawableStart="@android:drawable/ic_menu_edit"
                        android:drawablePadding="8dp"/>

                    <TextView
                        android:id="@+id/optimizedPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#000000"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#F2F2F2"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Statystyki"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:drawableStart="@android:drawable/ic_menu_info_details"
                        android:drawablePadding="8dp"/>

                    <TextView
                        android:id="@+id/stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#000000"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#F2F2F2"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Odpowiedź AI"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:drawableStart="@android:drawable/ic_btn_speak_now"
                        android:drawablePadding="8dp"/>

                    <TextView
                        android:id="@+id/aiResponsePreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="4"
                        android:ellipsize="end"
                        android:layout_marginTop="6dp"
                        android:textColor="#000000"/>

                    <TextView
                        android:id="@+id/btnShowFullResponse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zobacz pełną odpowiedź →"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>